# Example partial config for `terraform init -backend-config=...` with Scaleway Object Storage.
# Copy to a path outside version control (see `.gitignore` for `*.tfbackend`) or set the
# CI workflow repository variables TF_STATE_* instead.

bucket = "your-unique-bucket-name"
key    = "naira-playground/terraform.tfstate"
region = "fr-par"

endpoints = {
  s3 = "https://s3.fr-par.scw.cloud"
}

skip_credentials_validation = true
skip_requesting_account_id  = true
skip_metadata_api_check     = true
skip_region_validation      = true
use_path_style              = true
